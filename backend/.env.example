# Backend Configuration
DATABASE_URL=sqlite:///./cinematch.db
CORS_ORIGINS=http://localhost:3000,https://demo.cinematch.umans.ai

# TMDB API (optional - falls back to static movies if not set)
# Get free API key at: https://www.themoviedb.org/settings/api
# TMDB_API_KEY=your_api_key_here

# For production (use AWS Secrets Manager instead)
# DATABASE_URL=postgresql://user:pass@host/db
